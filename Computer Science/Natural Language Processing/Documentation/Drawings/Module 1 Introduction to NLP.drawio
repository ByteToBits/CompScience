        <mxCell id="7rbyWPkM07f5jrQSdIBZ-17" value="&lt;b style=&quot;font-family: &amp;quot;Comic Sans MS&amp;quot;; font-size: x-small;&quot;&gt;Split Strings into individual unit of words (tokens)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=0;strokeWidth=1;align=left;spacing=5;strokeColor=#000000;fillColor=#E6FFCC;fontColor=#1A1A1A;spacingBottom=1;fontSize=10;" parent="pQhNZeRnFEtJsWPPW5VE-1" vertex="1">
