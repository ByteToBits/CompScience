        <mxCell id="7rbyWPkM07f5jrQSdIBZ-16" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin-top: 0px; margin-bottom: 0px; padding: 8px;&quot;&gt;&lt;code style=&quot;padding: 0px; border-radius: 3px; word-break: break-word;&quot;&gt;&lt;font face=&quot;Comic Sans MS&quot; style=&quot;font-size: 10px;&quot; color=&quot;#000000&quot;&gt;&lt;b&gt;Sentence Tokenize                                  &lt;br&gt;&quot;Language is never random. Yes it is.&quot; → [&quot;Language is never random.&quot;, &quot;Yes it is.&quot;]  &lt;br&gt;                                                     &lt;br&gt;Word Tokenize each sentence + lowercase            &lt;br&gt;     → [[&quot;language&quot;,&quot;is&quot;,&quot;never&quot;,&quot;random&quot;],    [&quot;yes&quot;,&quot;it&quot;,&quot;is&quot;]]&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=0;strokeWidth=1;align=left;spacing=7;strokeColor=#000000;fillColor=#FFFFFF;fontColor=#1A1A1A;spacingBottom=1;" parent="pQhNZeRnFEtJsWPPW5VE-1" vertex="1">
