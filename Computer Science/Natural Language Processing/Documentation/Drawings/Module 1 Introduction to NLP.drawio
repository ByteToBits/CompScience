        </mxCell>
        <mxCell id="7rbyWPkM07f5jrQSdIBZ-21" value="&lt;font color=&quot;#000000&quot; face=&quot;Comic Sans MS&quot;&gt;&lt;b&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Move a fixed-size frame across the sentence, one word at a time, to extract every possible n-gram&lt;/span&gt;&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=0;strokeWidth=1;align=left;spacing=5;strokeColor=#000000;fillColor=#E5CCFF;fontColor=#1A1A1A;spacingBottom=1;fontSize=10;" parent="pQhNZeRnFEtJsWPPW5VE-1" vertex="1">
