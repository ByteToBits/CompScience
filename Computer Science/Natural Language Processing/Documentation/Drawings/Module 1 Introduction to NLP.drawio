        <mxCell id="6m5u0icq9fK1Vb_azOTs-99" value="&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&quot;king&quot;&amp;nbsp; &amp;nbsp;→ [0.2, 0.8, -0.3, ... 300 numbers] ,&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;font-size: 10px; font-family: &amp;quot;Comic Sans MS&amp;quot;; background-color: initial;&quot;&gt;&quot;queen&quot;&amp;nbsp; → [0.2, 0.7, -0.2, ... 300 numbers]&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&quot;banana&quot; → [-0.9, 0.1, 0.6, ... 300 numbers]&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;king.similarity(queen)&amp;nbsp; = 0.89&amp;nbsp; ✓ (semantically close),&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;font-size: 10px; font-family: &amp;quot;Comic Sans MS&amp;quot;; background-color: initial;&quot;&gt;king.similarity(banana) = 0.12&amp;nbsp; ✗ (semantically unrelated)&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=0;strokeWidth=1;align=left;spacing=7;strokeColor=#000000;fillColor=#FFFFFF;fontColor=#1A1A1A;spacingBottom=1;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;" parent="pQhNZeRnFEtJsWPPW5VE-1" vertex="1">
