        <mxCell id="7rbyWPkM07f5jrQSdIBZ-18" value="&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin-top: 0px; margin-bottom: 0px; padding: 8px;&quot;&gt;&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin-top: 0px; margin-bottom: 0px; padding: 8px;&quot;&gt;&lt;b&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;code style=&quot;padding: 0px; border-radius: 3px; word-break: break-word;&quot;&gt;&lt;font style=&quot;&quot; color=&quot;#000000&quot;&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;Add &amp;lt;s&amp;gt; and &amp;lt;/s&amp;gt; boundary tokens&lt;/font&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;  &lt;/font&gt;&lt;/font&gt;&lt;/code&gt;&lt;font face=&quot;Comic Sans MS&quot;&gt;(n=2 → 1 pad each side)  &lt;/font&gt;&lt;span style=&quot;color: rgb(0, 0, 0); background-color: initial; white-space: normal; font-family: &amp;quot;Comic Sans MS&amp;quot;;&quot;&gt;(n=3 → 2 pads each side)&amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;font-size: 10px; color: rgb(0, 0, 0); background-color: initial; white-space: normal; font-family: &amp;quot;Comic Sans MS&amp;quot;;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&lt;/span&gt;&lt;/b&gt;&lt;/pre&gt;&lt;pre style=&quot;overflow-x: auto; box-sizing: border-box; border-radius: 4px; max-width: 100%; margin-top: 0px; margin-bottom: 0px; padding: 8px;&quot;&gt;&lt;code style=&quot;padding: 0px; border-radius: 3px; word-break: break-word;&quot;&gt;&lt;font face=&quot;Comic Sans MS&quot; style=&quot;font-size: 10px;&quot; color=&quot;#000000&quot;&gt;&lt;b&gt;[&quot;language&quot;,&quot;is&quot;,&quot;never&quot;,&quot;random&quot;]   →  [&quot;&amp;lt;s&amp;gt;&quot;,&quot;language&quot;,&quot;is&quot;,&quot;never&quot;,&quot;random&quot;,&quot;&amp;lt;/s&amp;gt;&quot;]&lt;/b&gt;&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=0;strokeWidth=1;align=left;spacing=7;strokeColor=#000000;fillColor=#FFFFFF;fontColor=#1A1A1A;spacingBottom=1;" parent="pQhNZeRnFEtJsWPPW5VE-1" vertex="1">
          <mxGeometry x="2861" y="373.75" width="594.12" height="59.25" as="geometry" />
        </mxCell>
        <mxCell id="7rbyWPkM07f5jrQSdIBZ-19" value="&lt;font color=&quot;#000000&quot; face=&quot;Comic Sans MS&quot;&gt;&lt;b&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Adding&lt;/span&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt; special marker tokens at the start and end of a sentence&lt;/span&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt; so the model knows where sentences begin and end.&lt;/span&gt;&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=0;strokeWidth=1;align=left;spacing=5;strokeColor=#000000;fillColor=#FFCCFF;fontColor=#1A1A1A;spacingBottom=1;fontSize=10;" parent="pQhNZeRnFEtJsWPPW5VE-1" vertex="1">
          <mxGeometry x="2861" y="348.75" width="594.12" height="20" as="geometry" />
